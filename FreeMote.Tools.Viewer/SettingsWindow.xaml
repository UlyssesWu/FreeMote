<Window x:Class="FreeMote.Tools.Viewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Viewer Settings"
        Width="360"
        Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#202020">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="Gainsboro" Text="Playback speed"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <Slider x:Name="SpeedSlider" Width="150" Minimum="0.05" Maximum="3" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="SpeedSlider_ValueChanged"/>
            <TextBlock x:Name="SpeedValue" Width="48" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="Aquamarine" TextAlignment="Left"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,14,0,0" VerticalAlignment="Center" Foreground="Gainsboro" Text="Screenshot size"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,14,0,0" Orientation="Horizontal">
            <TextBox x:Name="WidthBox" Width="72" VerticalContentAlignment="Center"/>
            <TextBlock Margin="8,0" VerticalAlignment="Center" Foreground="Gainsboro" Text="x"/>
            <TextBox x:Name="HeightBox" Width="72" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="72" Margin="0,0,8,0" Content="Reset" Click="Reset_Click"/>
            <Button Width="72" Margin="0,0,8,0" Content="OK" IsDefault="True" Click="Ok_Click"/>
            <Button Width="72" Content="Cancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
